DISCORD_TOKEN=your-bot-token-here
DISCORD_APP_ID=your-application-id-here

# Master key for encrypting user-provided API keys at rest in SQLite.
# Generate a fresh one (32 random bytes, base64) with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Hex (64 chars) is also accepted. KEEP THIS SECRET and back it up —
# losing it means you can't decrypt stored keys; changing it means the
# same. If you rotate it, users must rerun `/config stt api_key:...`.
ENCRYPTION_KEY=

# Optional: when set, commands register only to this guild (instant update, dev-friendly).
# Leave empty for global command registration (can take up to 1 hour to propagate).
DISCORD_DEV_GUILD_ID=

# Optional: override the whisper.cpp binary name if it isn't `whisper-cli` on PATH.
# Older whisper.cpp builds use `main`. Can also be a full path to the .exe.
WHISPER_CPP_BIN=

# Folder containing GGML whisper models (ggml-<name>.bin). Defaults to <repo>/models.
# In deployed environments set this to the path baked into the image, e.g. /opt/whisper-models.
WHISPER_MODELS_DIR=

# Logging. LOG_LEVEL: debug | info | warn | error (default info).
# LOG_FORMAT: json for structured logs, anything else for human-readable.
LOG_LEVEL=info
LOG_FORMAT=

# Set to 1 to enable verbose @discordjs/voice gateway debug logs on /join.
VOICE_DEBUG=
