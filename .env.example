# ═══════════════════════════════════════════════════════════════════════════
# Nexus — Central AI Oracle
# Copy this file to .env and fill in your secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────
# Change this ONE line to switch database providers. That's it.
#
# PostgreSQL (local via docker-compose — recommended):
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5433/nexus
#
# PostgreSQL (hosted — swap when ready to deploy):
#   DATABASE_URL=postgresql+asyncpg://user:pass@your-rds-host.com:5432/nexus
#
# SQLite (zero dependencies, no Docker needed):
#   DATABASE_URL=sqlite+aiosqlite:///./dev.db
#
# How it works:
#   - The oracle reads DATABASE_URL and auto-configures SQLAlchemy.
#   - Alembic migrations work against both Postgres and SQLite.
#   - To switch: change the URL, run `cd oracle && alembic upgrade head`.
#   - docker-compose internally uses its own DATABASE_URL pointing at the
#     postgres container (postgres:5432), so POSTGRES_PORT only affects
#     the host-side port mapping for local dev tools.

# Docker Compose Postgres settings
POSTGRES_PASSWORD=nexus
POSTGRES_PORT=5433

# Legacy: Node.js adapters still read this for their local SQLite config.
# Removed in Phase 3 when adapters become stateless oracle clients.
DB_DRIVER=sqlite

# ── Encryption ───────────────────────────────────────────────────────────
# Shared between Oracle (Python) and adapters (Node.js).
# Both use the same AES-256-GCM format, so encrypted data is cross-runtime.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# Or:       node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-in-production

# ── Oracle Service ───────────────────────────────────────────────────────
ORACLE_PORT=8000
ORACLE_BASE_URL=http://localhost:8000

# ── Feature Flags ────────────────────────────────────────────────────────
# When true, adapters POST events to the oracle instead of running the
# local pipeline. Set to true once Phase 3 is complete.
USE_ORACLE=false

# ── Logging ──────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error
# LOG_FORMAT: json (structured) or blank (human-readable)
LOG_LEVEL=info
LOG_FORMAT=

# ── AI / LLM ────────────────────────────────────────────────────────────
OLLAMA_MODELS=llama3.1 gemma4 gemma4:31b
LLM_DEFAULT_MODEL=llama3.1

# ── Whisper (STT) ────────────────────────────────────────────────────────
WHISPER_CPP_BIN=
WHISPER_MODELS_DIR=
WHISPER_MODELS=tiny.en base.en small.en

# ── Discord ──────────────────────────────────────────────────────────────
ENABLE_DISCORD=true
DISCORD_TOKEN=your-bot-token-here
DISCORD_APP_ID=your-application-id-here
DISCORD_DEV_GUILD_ID=
VOICE_DEBUG=

# ── Slack ────────────────────────────────────────────────────────────────
ENABLE_SLACK=false
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
SLACK_PORT=3001