{
  "name": "ai-call-summarizer-discord-bot",
  "version": "0.1.0",
  "description": "Discord bot that joins voice calls, transcribes with speaker labels, and summarizes via a configurable LLM (Ollama by default).",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "start:discord": "node bin/start-discord.js",
    "start:slack": "node bin/start-slack.js",
    "slack:list-commands": "node bin/slack-list-commands.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.2",
    "@slack/bolt": "^4.7.1",
    "@slack/oauth": "^3.0.5",
    "@slack/web-api": "^7.15.1",
    "better-sqlite3": "^11.3.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "libsodium-wrappers": "^0.7.15",
    "prism-media": "^1.3.5",
    "undici": "^6.19.8"
  }
}
